<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Student Management System</display-name>

    <!-- Welcome file -->
    <welcome-file-list>
        <welcome-file>students</welcome-file>
    </welcome-file-list>

    <!-- List Students Servlet -->
    <servlet>
        <servlet-name>ListStudentServlet</servlet-name>
        <servlet-class>com.student.servlet.ListStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListStudentServlet</servlet-name>
        <url-pattern>/students</url-pattern>
    </servlet-mapping>

    <!-- Add Student Servlet -->
    <servlet>
        <servlet-name>AddStudentServlet</servlet-name>
        <servlet-class>com.student.servlet.AddStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddStudentServlet</servlet-name>
        <url-pattern>/add</url-pattern>
    </servlet-mapping>

    <!-- Update Student Servlet -->
    <servlet>
        <servlet-name>UpdateStudentServlet</servlet-name>
        <servlet-class>com.student.servlet.UpdateStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateStudentServlet</servlet-name>
        <url-pattern>/update</url-pattern>
    </servlet-mapping>

    <!-- Delete Student Servlet -->
    <servlet>
        <servlet-name>DeleteStudentServlet</servlet-name>
        <servlet-class>com.student.servlet.DeleteStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteStudentServlet</servlet-name>
        <url-pattern>/delete</url-pattern>
    </servlet-mapping>

</web-app>
